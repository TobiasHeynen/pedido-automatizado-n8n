      "parameters": {
        "jsCode": "const texto = $('Webhook').first().json.body.mensaje\n\n// sacamos \"!pedido \"\nconst limpio = texto.replace('!pedido ', '');\n\n// separamos por |\nconst partes = limpio.split('|');\n\nreturn [{\n  usuario: $json.usuario,\n  cuit_cuil :partes[0].trim(),\n  pedido: partes[1].trim(),\n  pago: partes[2].trim().toLowerCase(),\n  direccion: partes[3].trim(),\n  estado: 'pendiente_pago'\n}];"
