    {
      "parameters": {
        "jsCode": "let raw = $input.first().json.output[0].content[0].text;\n\ntry {\n  // 1. Eliminar bloques ```json ... ```\n  raw = raw.replace(/```json/g, '').replace(/```/g, '');\n\n  // 2. Quitar comillas externas si existen\n  if (raw.startsWith('\"') && raw.endsWith('\"')) {\n    raw = raw.slice(1, -1);\n  }\n\n  // 3. Limpiar caracteres escapados\n  raw = raw\n    .replace(/\\\\n/g, '')\n    .replace(/\\\\\"/g, '\"')\n    .replace(/\\\\t/g, '')\n    .trim();\n\n  // 4. Parsear\n  let parsed = JSON.parse(raw);\n\n  return [\n    {\n      json: parsed\n    }\n  ];\n\n} catch (error) {\n  return [\n    {\n      json: {\n        error: \"No se pudo parsear el JSON\",\n        limpio: raw\n      }\n    }\n  ];\n}"
      },
